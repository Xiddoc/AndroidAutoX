<?xml version="1.0" encoding="utf-8"?>
<!--
    Contained reveal for the "Reboot to apply" FAB + its glow halo.

    DESIGN INTENT
    ─────────────
    A gentle fade-in paired with a subtle uniform scale (0.85 → 1.0, pivot
    at the view's own centre) keeps every pixel of the glow halo within a
    bounded region that hugs the button corner.  No asymmetric pivot, no
    horizontal-only stretch — the blurred glow layers cannot smear sideways.

    WHY THE OLD ANIMATION WAS WRONG
    ────────────────────────────────
    The previous animation used:
        fromXScale="0.1"  toXScale="1.0"
        pivotX="100%"  pivotY="50%"           ← right-edge, vertical-centre pivot
    Applied to rebootContainer (clipChildren=false) whose children are large,
    heavily-blurred, negative-margin glow views, that produced a horizontal
    "streak" of blurred colour that grew from the right edge across almost the
    entire screen width before the container reached its natural size.

    THE FIX
    ───────
    • Scale both axes uniformly from 0.85 → 1.0 with pivot at the view's
      own centre (50%/50%).  The container's natural size is small (just the
      FAB + a bit of glow bleed), so even at 0.85 it is a tiny rectangle —
      not a screen-wide smear.
    • Alpha 0 → 1 (fully overlapping with the scale, no delay needed) so the
      glow fades up gracefully rather than popping.
    • Duration 400 ms keeps the reveal snappy without feeling abrupt.

    INVARIANT: at any moment during this animation the glow's on-screen
    bounding box is at most  containerNaturalSize × 1.0 / 0.85  ≈ 1.18×
    the container's resting size — entirely contained in the bottom-end
    corner.  This is verified by FabRevealGeometryTest (pure JVM, no device).
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:anim/decelerate_interpolator">

    <!-- Uniform scale from 85 % to 100 % of the container's natural size,
         pivoting about the container's own centre so the glow halo stays
         symmetric and localised.  0.85 was chosen so the button is clearly
         visible at the start of the reveal but there is still a perceivable
         "pop-in" motion.                                                    -->
    <scale
        android:fromXScale="0.85"
        android:toXScale="1.0"
        android:fromYScale="0.85"
        android:toYScale="1.0"
        android:pivotX="50%"
        android:pivotY="50%"
        android:duration="400" />

    <!-- Fade in over the same window so the glow materialises rather than
         appearing fully opaque at 85 % size.                                -->
    <alpha
        android:fromAlpha="0.0"
        android:toAlpha="1.0"
        android:duration="400" />

</set>
