<resources>

    <!-- Base application theme: always-on dark navy brand theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/brand_navy</item>
        <item name="colorPrimaryDark">@color/brand_navy_dark</item>
        <item name="colorAccent">@color/brand_blue</item>
        <item name="android:colorBackground">@color/brand_navy</item>
        <item name="android:windowBackground">@color/brand_navy</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_muted</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="TitleBarTextAppearance" parent="android:TextAppearance">
        <item name="android:fontFamily">@font/raleway_semibold</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/dialog_text_color</item>
    </style>

    <style name="NormalTextAppeareance" parent="android:TextAppearance">
        <item name="android:fontFamily">@font/raleway_medium</item>
        <item name="android:textColor">@color/dialog_text_color</item>
    </style>

    <style name="MyActionBarTheme" parent="ThemeOverlay.AppCompat.ActionBar">
        <item name="android:background">?colorPrimary</item>
        <item name="popupTheme">?titleTextColor</item>
        <item name="tint">?titleTextColor</item>
    </style>

    <style name="MenuTheme">
        <item name="android:colorBackground">@color/menu_background</item>
        <item name="android:textColor">@color/menu_text_color</item>
    </style>

    <style name="ButtonStyle">
        <!-- Edge insets handled in layout; more vertical breathing room.
             Use explicit top/bottom margins (layout_marginVertical is API 26+). -->
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:background">@drawable/button_background</item>
        <item name="android:fontFamily">@font/raleway_medium</item>
        <item name="android:gravity">center</item>
        <item name="android:textAllCaps">false</item>
        <!-- Rely on the drawable glow for depth; drop the platform shadow animator -->
        <item name="android:stateListAnimator">@null</item>
    </style>


    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="BottomSheet" parent="@style/Widget.Design.BottomSheet.Modal">
        <item name="android:background">@drawable/bottom_sheet_bg</item>
    </style>

    <style name="BaseBottomSheetDialog" parent="@style/Theme.Design.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="bottomSheetStyle">@style/BottomSheet</item>
    </style>

</resources>
