<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:theme="@style/AppTheme"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".MainActivity">

    <!-- Ambient AI backdrop: soft colour blobs that slowly drift and breathe
         behind the content the whole time the app is open (animated in
         MainActivity#startAurora). Fills the screen, drawn first = behind
         everything; blobs bleed past the edges (clipChildren=false) for a
         natural aurora. The translucent surfaces above let it glow through. -->
    <FrameLayout
        android:id="@+id/aurora_layer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/aurora_blob1"
            android:layout_width="380dp"
            android:layout_height="380dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="-80dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/aurora_blob_blue" />

        <View
            android:id="@+id/aurora_blob2"
            android:layout_width="440dp"
            android:layout_height="440dp"
            android:layout_gravity="center|end"
            android:layout_marginEnd="-120dp"
            android:background="@drawable/aurora_blob_purple" />

        <View
            android:id="@+id/aurora_blob3"
            android:layout_width="420dp"
            android:layout_height="420dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="-60dp"
            android:layout_marginBottom="-40dp"
            android:background="@drawable/aurora_blob_pink" />
    </FrameLayout>

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        app:titleTextAppearance="@style/TitleBarTextAppearance"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:theme="@style/MyActionBarTheme"
        app:contentInsetEndWithActions="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:popupTheme="@style/MenuTheme">

        <TextView
            android:id="@+id/version_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="4dp"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:fontFamily="@font/raleway_medium" />
    </androidx.appcompat.widget.Toolbar>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        app:tabTextColor="@color/text_muted"
        app:tabSelectedTextColor="@color/text_primary"
        app:tabIndicatorColor="@color/accent_blue"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/info_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="@drawable/info_card_bg"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/tab_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/info_card_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/welcome_title"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:fontFamily="@font/raleway_semibold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/info_card_dismiss" />

        <ImageButton
            android:id="@+id/info_card_dismiss"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="@string/dismiss"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/info_card_body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/main_string"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:fontFamily="@font/raleway_light"
            app:layout_constraintTop_toBottomOf="@id/info_card_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.viewpager.widget.ViewPager
        android:id="@+id/viewpager"
        app:layout_constraintTop_toBottomOf="@id/info_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="match_parent"
        android:layout_height="0dp">

        <include
            android:id="@+id/page_one"
            layout="@layout/scrollview"
            android:layout_height="0dp"
            android:layout_width="0dp"/>

        <include
            android:id="@+id/page_two"
            android:layout_height="0dp"
            android:layout_width="0dp"
            layout="@layout/scrollview_second" />

        <include
            android:id="@+id/page_three"
            android:layout_height="0dp"
            android:layout_width="0dp"
            layout="@layout/scrollview_settings" />

    </androidx.viewpager.widget.ViewPager>

    <!-- Floating "Reboot to apply" action button. Shown (VISIBLE/GONE toggled by
         RebootFabController) once a tweak is applied. Kept inside a FrameLayout so
         the controller has a single root view to toggle. -->
    <FrameLayout
        android:id="@+id/reboot_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="15dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/reboot_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/fab_background"
            android:elevation="6dp"
            android:clickable="true"
            android:drawableStart="@drawable/ic_baseline_settings_backup_restore_24"
            android:drawablePadding="5dp"
            android:focusable="true"
            android:text="@string/reboot_to_apply"
            android:textColor="@android:color/white" />
    </FrameLayout>


</androidx.constraintlayout.widget.ConstraintLayout>