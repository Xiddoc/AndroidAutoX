<?xml version="1.0" encoding="utf-8"?>
<!-- Inner, bright rim of the FAB glow. The puck is INSET inside its (larger)
     view so the runtime RenderEffect blur has transparent margin to bloom into
     instead of being clipped at the view edge. A diagonal blue -> purple -> pink
     gradient gives the bright multi-hue Gemini rim hugging the button body. -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetLeft="14dp"
    android:insetTop="14dp"
    android:insetRight="14dp"
    android:insetBottom="14dp">
    <shape android:shape="rectangle">
        <corners android:radius="20dp" />
        <gradient
            android:type="linear"
            android:angle="45"
            android:startColor="@color/gemini_blue"
            android:centerColor="@color/gemini_purple"
            android:endColor="@color/gemini_pink" />
    </shape>
</inset>
