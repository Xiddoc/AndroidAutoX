<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Existing 3-stop navy gradient body (preserved & enhanced, not flattened).
         Drawn at 0 inset as the bottom layer so the gradient fills the full
         silhouette (no 1px edge artifact). -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="15dp" />
            <gradient
                android:angle="-90"
                android:centerX="0.35"
                android:centerY="0.95"
                android:endColor="@color/bottomcolor"
                android:centerColor="@color/centercolor"
                android:startColor="@color/topcolor"
                android:type="linear" />
        </shape>
    </item>

    <!-- BOLD NEON GLOW (subtler than buttons, same unified blue hue #2196F3).
         2-step blue ring halo drawn ON TOP, inset inward. -->

    <!-- Faint outer ring (alpha 14), radius 15dp at bounds edge -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="15dp" />
            <stroke
                android:width="2dp"
                android:color="@color/glow_blue_ring_card_outer" />
        </shape>
    </item>

    <!-- Brighter inner ring (alpha 55), inset 2dp -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="13dp" />
            <stroke
                android:width="1dp"
                android:color="@color/glow_blue_ring_card_inner" />
        </shape>
    </item>

    <!-- Bright ACCENT-colored full rim (blue, not cyan/chrome) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="15dp" />
            <stroke
                android:width="1dp"
                android:color="@color/glow_rim_soft" />
        </shape>
    </item>

</layer-list>
