<?xml version="1.0" encoding="utf-8"?>
<!-- Ambient "aurora" blob: a soft radial bloom that fades to transparent. Several
     of these drift/breathe behind the content (see MainActivity#startAurora) to
     give the app a dynamic, AI-app feel. Blue lobe. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="radial"
        android:gradientRadius="200dp"
        android:centerX="0.5"
        android:centerY="0.5"
        android:startColor="#734285F4"
        android:endColor="#004285F4" />
</shape>
