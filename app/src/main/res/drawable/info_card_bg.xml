<?xml version="1.0" encoding="utf-8"?>
<!-- Glassy info card: translucent, top-lit navy panel with a bright hairline
     edge so the ambient aurora glows through it (frosted glass). Slightly more
     opaque than the buttons since it carries body text. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="16dp" />
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#A63E5163"
        android:endColor="#99202C36" />
    <stroke android:width="1dp" android:color="#45FFFFFF" />
</shape>
