<?xml version="1.0" encoding="utf-8"?>
<!-- Glassy tweak surface: a translucent, top-lit navy panel with a bright
     hairline edge. Because it's semi-transparent, the soft ambient aurora behind
     the content glows through it (frosted-glass look), while staying opaque
     enough to keep label text legible. Ripple feedback on top. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/ripple_light">

    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#993E5163"
                android:endColor="#8C202C36" />
            <stroke android:width="1dp" android:color="#45FFFFFF" />
            <padding
                android:left="16dp"
                android:right="16dp"
                android:top="14dp"
                android:bottom="14dp" />
        </shape>
    </item>
</ripple>
