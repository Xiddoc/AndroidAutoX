<?xml version="1.0" encoding="utf-8"?>
<!-- Tonal tweak surface (Material-3 style): a calm elevated navy card with a
     hairline outline and ripple feedback. The bright logo blue is reserved for
     accents (slider, tab, FAB), so the list stays calm and legible. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/ripple_light">

    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/brand_surface" />
            <stroke android:width="1dp" android:color="@color/surface_outline" />
            <padding
                android:left="16dp"
                android:right="16dp"
                android:top="14dp"
                android:bottom="14dp" />
        </shape>
    </item>
</ripple>
