<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/ripple_light">

    <!-- Touch-feedback mask: confined to the visible button body (inside the halo).
         Body is inset 6dp with a 12dp radius, so the mask matches it exactly. -->
    <item android:id="@android:id/mask">
        <inset
            android:insetLeft="6dp"
            android:insetTop="6dp"
            android:insetRight="6dp"
            android:insetBottom="6dp">
            <shape android:shape="rectangle">
                <solid android:color="@color/accent_blue" />
                <corners android:radius="12dp" />
            </shape>
        </inset>
    </item>

    <item android:id="@android:id/background">
        <layer-list>

            <!-- BOLD NEON GLOW: three stacked blue stroke rings outside the body,
                 stepped alpha (1A -> 55 -> AA). Radii stepped with inset so the
                 rings stay concentric/parallel to the 12dp body corner. -->

            <!-- Outer ring: full bounds, faintest (alpha 1A), radius 18dp -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="18dp" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/glow_blue_ring_outer" />
                </shape>
            </item>

            <!-- Mid ring: inset 3dp, mid alpha (55), radius 15dp -->
            <item
                android:left="3dp"
                android:top="3dp"
                android:right="3dp"
                android:bottom="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="15dp" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/glow_blue_ring_mid" />
                </shape>
            </item>

            <!-- Inner luminous ring: inset 5dp, brightest (alpha AA), radius 13dp.
                 This bright ring hugging the body is what sells the neon look. -->
            <item
                android:left="5dp"
                android:top="5dp"
                android:right="5dp"
                android:bottom="5dp">
                <shape android:shape="rectangle">
                    <corners android:radius="13dp" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/glow_blue_ring_inner" />
                </shape>
            </item>

            <!-- Main body: inset 6dp, vertical gradient (lighter top -> base accent
                 bottom) for depth. Original 16dp/8dp padding lives here so the label
                 sits inside the halo and isn't clipped. -->
            <item
                android:left="6dp"
                android:top="6dp"
                android:right="6dp"
                android:bottom="6dp">
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <gradient
                        android:angle="90"
                        android:startColor="@color/accent_blue"
                        android:endColor="@color/accent_blue_top"
                        android:type="linear" />
                    <padding
                        android:left="16dp"
                        android:right="16dp"
                        android:top="8dp"
                        android:bottom="8dp" />
                </shape>
            </item>

            <!-- Bright ACCENT-colored rim hugging the body (neon, not chrome) -->
            <item
                android:left="6dp"
                android:top="6dp"
                android:right="6dp"
                android:bottom="6dp">
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/glow_rim_bright" />
                </shape>
            </item>

        </layer-list>
    </item>
</ripple>
