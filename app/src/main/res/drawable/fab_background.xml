<?xml version="1.0" encoding="utf-8"?>
<!-- Filled accent FAB (extended): the one loud blue element. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="@color/brand_blue_dark" />
            <padding android:left="16dp" android:top="12dp" android:right="16dp" android:bottom="12dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="@color/brand_blue" />
            <padding android:left="16dp" android:top="12dp" android:right="16dp" android:bottom="12dp" />
        </shape>
    </item>
</selector>
