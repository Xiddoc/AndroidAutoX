<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <layer-list>

            <!-- BOLD NEON GLOW: blue stepped-ring halo around the 18dp body.
                 Same unified blue hue (#2196F3) and vocabulary as the buttons.
                 Body stays inset 3dp / radius 18dp; rings sized concentrically. -->

            <!-- Outer ring: full bounds, faintest (alpha 1A), radius 21dp -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="21dp" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/glow_blue_ring_outer" />
                </shape>
            </item>

            <!-- Inner luminous ring: inset 1dp, brightest (alpha AA), radius 20dp.
                 Hugs the body to read as neon rather than a plain border. -->
            <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="20dp" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/glow_blue_ring_inner" />
                </shape>
            </item>

            <!-- Body: inset 3dp, smooth vertical gradient (avoids a harsh two-tone
                 jump). Original 10dp/5dp padding preserved on this layer. -->
            <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="18dp" />
                    <gradient
                        android:angle="90"
                        android:startColor="@color/brand_blue"
                        android:endColor="@color/fab_blue_top"
                        android:type="linear" />
                    <padding
                        android:left="10dp"
                        android:top="5dp"
                        android:right="10dp"
                        android:bottom="5dp" />
                </shape>
            </item>

            <!-- Bright ACCENT-colored rim hugging the body (neon, not chrome) -->
            <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="18dp" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/glow_rim_bright" />
                </shape>
            </item>

        </layer-list>
    </item>
</selector>
