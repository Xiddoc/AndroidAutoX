<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">


    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- AutoX virtual-display projection: keep the service alive while projecting -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE"/>
    <!-- AutoX: PARTIAL_WAKE_LOCK to prevent CPU suspension during projection -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <!-- Car App: required to use navigation templates in the Android Auto host -->
    <uses-permission android:name="androidx.car.app.NAVIGATION_TEMPLATES"/>

    <application
        android:name=".AaxApp"
        android:allowBackup="true"
        tools:replace="android:theme"
        android:fullBackupContent="@xml/backup_descriptor"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:screenOrientation="portrait"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme.NoActionBar">

        <!-- Car App: minimum Car API level required by AutoXCarAppService -->
        <meta-data
            android:name="androidx.car.app.minCarApiLevel"
            android:value="1"/>
        <!-- Car App: descriptor that tells the Android Auto host this app uses templates -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc"/>

        <!-- WS4 LSPosed module declaration. The hook entry class is named in
             assets/xposed_init. xposedscope targets system_server (package "android")
             so the privileged hooks (trusted display, input injection, per-display IME /
             system decors, launch-on-display) run there. The classes are provided by
             LSPosed at runtime (compileOnly), never bundled. -->
        <meta-data
            android:name="xposedmodule"
            android:value="true"/>
        <meta-data
            android:name="xposeddescription"
            android:value="@string/xposed_module_description"/>
        <!-- LSPosed/Xposed framework API level this module requires. -->
        <meta-data
            android:name="xposedminversion"
            android:value="93"/>
        <!-- Process scope this module hooks. -->
        <meta-data
            android:name="xposedscope"
            android:resource="@array/xposed_scope"/>
        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <category android:name="android.intent.category.LAUNCHER"/>
                <action android:name="android.intent.action.MAIN" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|keyboardHidden"
            android:exported="true"
            android:launchMode="singleTop">
        </activity> <!-- A child of the main activity -->
        <activity
            android:name=".AppsList"
            android:configChanges="orientation|keyboardHidden"
            android:label="@string/app_list_label"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".AccountsChooseActivity.AccountsChooser"
            android:configChanges="orientation|keyboardHidden" />

        <activity
            android:name=".CarRemoverActivity.CarRemover"
            android:configChanges="orientation|keyboardHidden" />

        <!-- Background re-apply so tweaks survive GMS re-syncs without opening the app -->
        <service
            android:name=".ReapplyJobService"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="false" />

        <!-- libsu root service: opens GMS's phenotype.db in a root process via the
             platform SQLite API. Declared with no android:process; libsu manages it. -->
        <service
            android:name=".PhixitRootService"
            android:exported="false" />

        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- AutoX Car App service: discovered by the Android Auto host as a
             NAVIGATION-category car app. exported=true is required so the host
             (a separate process) can bind to this service. -->
        <service
            android:name=".autox.AutoXCarAppService"
            android:exported="true">
            <intent-filter>
                <action android:name="androidx.car.app.CarAppService"/>
                <category android:name="androidx.car.app.category.NAVIGATION"/>
            </intent-filter>
        </service>

        <!-- AutoX foreground service: holds a PARTIAL_WAKE_LOCK and a foreground
             notification while the projection session is active.
             foregroundServiceType=specialUse: the connectedDevice type enforces Android 14
             runtime preconditions (companion-device association) that this rooted projection
             tool does not satisfy; specialUse has no such precondition. The required subtype
             is declared via the PROPERTY_SPECIAL_USE_FGS_SUBTYPE property below.
             exported=false: not accessible from other apps. -->
        <service
            android:name=".autox.AutoXForegroundService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="android_auto_projection"/>
        </service>

    </application>

</manifest>